# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/buchhaltung
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/buchhaltung
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=buchhaltung

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=...
TAVILY_API_KEY=

# LangSmith (optional — default OFF for GDPR)
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=ai-buchhaltung
LANGCHAIN_TRACING_V2=false

# OpenAI (optional)
OPENAI_API_KEY=...

# Encryption secret for stored API keys (64-char hex = 32 bytes)
# Generate with: python -c "import os; print(os.urandom(32).hex())"
LLM_KEY_ENCRYPTION_SECRET=

# Extended Thinking (optional)
THINKING_BUDGET_TOKENS=8000
THINKING_CONFIDENCE_THRESHOLD=0.7

# Backend
BACKEND_URL=http://backend:8000
UPLOAD_DIR=/app/uploads
EXPORT_DIR=/app/exports

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
